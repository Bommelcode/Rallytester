<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808">

    <!-- ── USB UVC Camera preview (SurfaceView for AndroidUSBCamera) ── -->
    <SurfaceView
        android:id="@+id/surfaceCamera"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/rightPanel" />

    <!-- Overlay: "geen camera" placeholder -->
    <TextView
        android:id="@+id/tvNoCameraOverlay"
        android:text="📷\nGeen USB camera\ngedetecteerd"
        android:textColor="#444444"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/rightPanel"
        android:visibility="visible"/>

    <!-- ── Right panel ── -->
    <LinearLayout
        android:id="@+id/rightPanel"
        android:layout_width="260dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="14dp"
        android:background="#101010"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Header -->
        <TextView
            android:text="RALLY TESTER"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingBottom="2dp"/>

        <!-- Connection status badge -->
        <TextView
            android:id="@+id/tvStatus"
            android:text="⬤  Verbinden..."
            android:textSize="11sp"
            android:textColor="#FFA726"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingBottom="10dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#252525"/>

        <!-- ── MIC INPUT ── -->
        <TextView
            android:text="MIC INPUT"
            style="@style/SectionLabel"
            android:paddingTop="10dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="2dp">
            <TextView android:text="L" style="@style/ChannelLabel"/>
            <com.example.rallytester.VuMeterView
                android:id="@+id/vuMeterLeft"
                android:layout_width="0dp"
                android:layout_height="20dp"
                android:layout_weight="1"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
            <TextView android:text="R" style="@style/ChannelLabel"/>
            <com.example.rallytester.VuMeterView
                android:id="@+id/vuMeterRight"
                android:layout_width="0dp"
                android:layout_height="20dp"
                android:layout_weight="1"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvPeakDb"
            android:text="Peak: –– dBFS"
            android:textSize="10sp"
            android:textColor="#AAAAAA"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="8dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#252525"/>

        <!-- ── SPEAKER OUTPUT ── -->
        <TextView
            android:text="SPEAKER OUTPUT"
            style="@style/SectionLabel"
            android:paddingTop="10dp"/>

        <com.example.rallytester.VuMeterView
            android:id="@+id/vuMeterOutput"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:layout_marginBottom="8dp"/>

        <!-- Frequency buttons -->
        <TextView
            android:text="Frequentie testtoon:"
            android:textSize="9sp"
            android:textColor="#888888"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button android:id="@+id/btn80"   android:text="80 Hz"  style="@style/FreqBtn" android:layout_marginEnd="3dp"/>
            <Button android:id="@+id/btn440"  android:text="440 Hz" style="@style/FreqBtn" android:layout_marginEnd="3dp"/>
            <Button android:id="@+id/btn1000" android:text="1 kHz"  style="@style/FreqBtn"/>
        </LinearLayout>

        <!-- Play / stop -->
        <Button
            android:id="@+id/btnPlayTone"
            android:text="▶  Testtoon afspelen"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="6dp"
            android:textSize="11sp"
            android:backgroundTint="#1565C0"/>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#252525" android:layout_marginBottom="6dp"/>

        <!-- Echo loopback -->
        <Button
            android:id="@+id/btnEchoTest"
            android:text="🔁  Echo loopback test"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="6dp"
            android:textSize="11sp"
            android:backgroundTint="#2E7D32"/>

        <TextView
            android:id="@+id/tvEchoResult"
            android:text=""
            android:textSize="10sp"
            android:textColor="#80CBC4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:minLines="2"/>

        <!-- Spacer -->
        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

        <!-- Device info footer -->
        <TextView
            android:id="@+id/tvDeviceInfo"
            android:text="USB: zoeken..."
            android:textSize="8sp"
            android:textColor="#444444"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
